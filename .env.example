# Copy this file to .env and fill in your Supabase project values.
# Never commit your real .env file — it is already in .gitignore.
#
# Where to find these values:
# 1. Go to https://supabase.com/dashboard and open your project
# 2. Go to Project Settings -> API
# 3. VITE_SUPABASE_URL      = "Project URL"
# 4. VITE_SUPABASE_ANON_KEY = "anon / public" key (NOT the service_role key)
#
# Full setup walkthrough: see SUPABASE_SETUP.md at the project root.

VITE_SUPABASE_URL=your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
